<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="edu.nnuzb.jiguo.dao.CoolItemThumbDao">
    <insert id="insertCoolItemThumb">
        insert into jg_cool_item_thumb
        values(0,#{userId},#{itemId})
    </insert>
    <delete id="deleteCoolItemThumb">
        delete from jg_cool_item_thumb
        where item_id=#{itemId} and user_id=#{userId}
    </delete>
    <select id="selectByItemIdAndUserId" resultType="int">
        select count(1) from jg_cool_item_thumb
        where item_id=#{itemId} and user_id=#{userId}
    </select>
</mapper>